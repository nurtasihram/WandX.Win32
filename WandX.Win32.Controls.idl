#pragma region Control StatusBar
enum_flags(StatusBarStyle     , WStyle           ,
		   SizeGripb          = SBARS_SIZEGRIP   ,
		   ToolTips           = SBARS_TOOLTIPS   );
enum_flags(StatusBarTextStyle , Int16U,
		   Default            = 0                ,
		   OwnerDraw          = SBT_OWNERDRAW    ,
		   NoBorders          = SBT_NOBORDERS    ,
		   PopOut             = SBT_POPOUT       ,
