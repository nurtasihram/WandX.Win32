	proxy_prop_set(States,tbs,ToolBarState);
	proxy_prop_get(States,fsState,ToolBarState);
public: // Property - Styles
	proxy_prop_set(Styles,tbbs,ToolBarButtonStyle);
	proxy_prop_get(Styles,fsStyle,ToolBarButtonStyle);
