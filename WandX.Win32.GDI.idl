class BaseOf_GDI(Region, HRGN) {
public:
	using Super = GObjectBase<Region, HRGN>;
protected:
	proxy_basetype(Region);
	Region(HRGN h) : Super(h) {}
	Region(const Region &r) : Super(r) {}
public:
	Region() {}
	Region(Nu) {}
	Region(Region &r) : Super(r) {}
	Region(Region &&r) : Super(r) {}
public:
//	static inline void Combine() { CombineRgn() }
public:
	static inline Region CreateRect(WandX::Rect rc) ret_as(WandX::CreateRectRgn(rc.left, rc.top, rc.right, rc.bottom));
	static inline Region CreateElliptic(WandX::Rect rc) ret_as(WandX::CreateEllipticRgn(rc.left, rc.top, rc.right, rc.bottom));
	static inline Region CreateRound(WandX::Rect rc, WandX::Size sz) ret_as(WandX::CreateRoundRectRgn(rc.left, rc.top, rc.right, rc.bottom, sz.cx, sz.cy));
	static inline Region CreatePolygon(const POINT *ppt1, int cPoint, PolyFillModes mode = PolyFillModes::Winding) ret_as(WandX::CreatePolygonRgn(ppt1, cPoint, mode.yield()));
	static inline Region CreatePolyPolygon(const POINT *ppt1, int cPoint, PolyFillModes mode = PolyFillModes::Winding) ret_as(WandX::CreatePolygonRgn(ppt1, cPoint, mode.yield()));
public:
	inline bool Equal(HRGN hRgn) ret_as(WandX::EqualRgn(self, hRgn));
	inline bool Has(Point pt) ret_as(WandX::PtInRegion(self, pt.x, pt.y));
	inline bool Has(WandX::Rect rc) ret_as(WandX::RectInRegion(self, &rc));
public:
	inline void And(HRGN hRgn) { WandX::CombineRgn(self, self, hRgn, RGN_AND); }
	inline void And(HRGN hRgn1, HRGN hRgn2) { WandX::CombineRgn(self, hRgn1, hRgn2, RGN_AND); }
	inline void Or(HRGN hRgn) { WandX::CombineRgn(self, self, hRgn, RGN_OR); }
	inline void Or(HRGN hRgn1, HRGN hRgn2) { WandX::CombineRgn(self, hRgn1, hRgn2, RGN_OR); }
	inline void Xor(HRGN hRgn) { WandX::CombineRgn(self, self, hRgn, RGN_XOR); }
	inline void Xor(HRGN hRgn1, HRGN hRgn2) { WandX::CombineRgn(self, hRgn1, hRgn2, RGN_XOR); }
	inline void Diff(HRGN hRgn) { WandX::CombineRgn(self, self, hRgn, RGN_DIFF); }
	inline void Diff(HRGN hRgn1, HRGN hRgn2) { WandX::CombineRgn(self, hRgn1, hRgn2, RGN_DIFF); }
	inline void Offset(Point off) { WandX::OffsetRgn(self, off.x, off.y); }
public:
	inline auto &operator&(HRGN hRgn) ret_to_self(And(hRgn));
	inline auto &operator|(HRGN hRgn) ret_to_self(Or(hRgn));
	inline auto &operator^(HRGN hRgn) ret_to_self(Xor(hRgn));
	inline auto &operator-(HRGN hRgn) ret_to_self(Diff(hRgn));
};
using CRegion = ProxyView<Region>;
#pragma endregion

