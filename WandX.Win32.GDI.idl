		   Horizontal  = HS_HORIZONTAL ,   /* ----- */
		   Vertical    = HS_VERTICAL   ,   /* ||||| */
		   FDiagonal   = HS_FDIAGONAL  ,   /* \\\\\ */
		   BDiagonal   = HS_BDIAGONAL  ,   /* ///// */
