class BaseOf_GDI(DevCap, HDC) {
public:
	using Super = GObjectBase<DevCap, HDC>;
protected:
	proxy_basetype(DevCap);
	DevCap(HDC h) : Super(h) {}
	DevCap(const DevCap &d) : Super(d) {}
public:
	DevCap() {}
	DevCap(Nu) {}
	DevCap(DevCap &d) : Super(d) {}
	DevCap(DevCap &&d) : Super(d) {}
	~DevCap() ret_to(Delete());
public:
	static inline DevCap CreateCompatible(HDC hdc = O) ret_as(WandX::CreateCompatibleDC(hdc));
public:
	//inline void Delete() {
	//	if (self)
	//		nt_assert(DeleteDC(self));
	//	this->hobj = O;
	//}
	inline auto Release(HWND hWnd) ret_as(WandX::ReleaseDC(hWnd, self));

	inline CGObject Select(HGDIOBJ ho) ret_as(::SelectObject(self, ho));
	inline CPalette Palette(HPALETTE hPal, bool bForceBkgd = false) ret_to(hPal = WandX::SelectPalette(self, hPal, bForceBkgd), hPal);
	inline UINT PaletteRealize() const ret_as(WandX::RealizePalette(self));

//	inline auto &BltStretch(Point dstStart, WandX::Size dstSize, Rop rop = Rop::SrcCopy)
	inline auto &BltStretch(Point dstStart, WandX::Size dstSize, HDC hdcSrc, Point srcStart, WandX::Size srcSize, Rop rop = Rop::SrcCopy) ret_to_self(WandX::StretchBlt(self, dstStart.x, dstStart.y, dstSize.cx, dstSize.cy, hdcSrc, srcStart.x, srcStart.y, srcSize.cx, srcSize.cy, rop.yield()));
	inline auto &BltStretch(WandX::Rect dst, HDC hdcSrc, WandX::Rect src, Rop rop = Rop::SrcCopy) ret_to_self(BltStretch(dst.left_top(), dst.size(), hdcSrc, src.left_top(), src.size(), rop));
	inline auto &BltBit(Point dstStart, WandX::Size dstSize, HDC hdcSrc, Point srcStart = 0, Rop rop = Rop::SrcCopy) ret_to_self(WandX::BitBlt(self, dstStart.x, dstStart.y, dstSize.cx, dstSize.cy, hdcSrc, srcStart.x, srcStart.y, rop.yield()));
	inline auto &BltBit(WandX::Rect rc, HDC hdcSrc, Point srcStart = 0, Rop rop = Rop::SrcCopy) ret_to_self(BltBit(rc.left_top(), rc.size(), hdcSrc, srcStart, rop));

	template<SizeT len>
	inline auto &DrawPolyline(const POINT(&pts)[len]) ret_to_self(WandX::Polyline(self, &pts, len));
	template<SizeT len>
	inline auto &DrawPolyline(const Point(&pts)[len]) ret_to_self(WandX::Polyline(self, (CONST POINT *)&pts, len));
	inline auto &DrawPolyline(const Point *pts, int len) ret_to_self(WandX::Polyline(self, (CONST POINT *)pts, len));
	inline auto &DrawPolyline(const POINT *pts, int len) ret_to_self(WandX::Polyline(self, pts, len));
	inline auto &DrawIcon(HICON hIcon, Point p = 0) ret_to_self(WandX::DrawIcon(self, p.x, p.y, hIcon));
	inline int  DrawText(String text, WandX::Rect r = 0, TextDraw format = TextDraw::Left) ret_as(WandX::DrawText(self, text, (int)text.Length(), r, format.yield()));
	inline auto &DrawPixel(COLORREF rgb, Point p) ret_to_self(WandX::SetPixel(self, p.x, p.y, rgb));
	inline auto &DrawPie(WandX::Rect rc, Point start, Point end) ret_to_self(WandX::Pie(self, rc.left, rc.top, rc.right, rc.bottom, start.x, start.y, end.x, end.y));
	inline auto &DrawEllipse(WandX::Rect rc) ret_to_self(Ellipse(self, rc.left, rc.top, rc.right, rc.bottom));
	inline auto &DrawFrame(WandX::Rect rc) ret_to_self(WandX::InvertRect(self, rc));
	inline auto &DrawFocus(HBRUSH hbr, WandX::Rect rc) ret_to_self(WandX::FrameRect(self, &rc, hbr));
	inline auto &Invert(WandX::Rect rc) ret_to_self(WandX::InvertRect(self, rc));
	inline auto &Fill(HBRUSH hbr, WandX::Rect rc) ret_to_self(WandX::FillRect(self, rc, hbr));
	inline auto &Fill(HBRUSH hbr) ret_as(Fill(hbr, Size()));
public:
	class IPixel {
		friend class DevCap;
		HDC hdc;
		POINT pt;
	private:
		IPixel(const IPixel &) = delete;
		IPixel(HDC hdc, POINT pt) : hdc(hdc), pt(pt) {}
	public:
		IPixel(IPixel &&) = default;
	public:
		inline operator RGBColor() const ret_as(WandX::GetPixel(hdc, pt.x, pt.y));
		inline operator COLORREF() const ret_as(WandX::GetPixel(hdc, pt.x, pt.y));
		inline void operator=(COLORREF clr) ret_to(WandX::SetPixel(hdc, pt.x, pt.y, clr));
	};
	inline IPixel Pixel(Point pt) ret_as({ self, pt });
	inline const IPixel Pixel(Point pt) const ret_as({ self, pt });

