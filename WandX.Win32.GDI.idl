public:
	Pen() {}
	Pen(Nu) {}
	Pen(Pen &p) : Super(p) {}
	Pen(Pen &&p) : Super(p) {}
	Pen(const PenLogic &log) : Super(Create(log)) {}
public:
	static inline Pen Create(const PenLogic &log) ret_as(WandX::CreatePenIndirect(&log));
	static inline Pen Create(Styles styles, COLORREF rgb, int nWidth = 0) ret_as(WandX::CreatePen(styles.yield(), nWidth, rgb));
	static inline Pen CreateSolid(COLORREF rgb, int nWidth = 0)       ret_as(WandX::CreatePen(PS_SOLID, nWidth, rgb));
	static inline Pen CreateDash(COLORREF rgb, int nWidth = 0)        ret_as(WandX::CreatePen(PS_DASH, nWidth, rgb));
	static inline Pen CreateDot(COLORREF rgb, int nWidth = 0)         ret_as(WandX::CreatePen(PS_DOT, nWidth, rgb));
	static inline Pen CreateDashDot(COLORREF rgb, int nWidth = 0)     ret_as(WandX::CreatePen(PS_DASHDOT, nWidth, rgb));
	static inline Pen CreateDashDotDot(COLORREF rgb, int nWidth = 0)  ret_as(WandX::CreatePen(PS_DASHDOTDOT, nWidth, rgb));
	static inline Pen CreateNull(COLORREF rgb, int nWidth = 0)        ret_as(WandX::CreatePen(PS_NULL, nWidth, rgb));
	static inline Pen CreateInsideFrame(COLORREF rgb, int nWidth = 0) ret_as(WandX::CreatePen(PS_INSIDEFRAME, nWidth, rgb));
	static inline Pen CreateUserStyle(COLORREF rgb, int nWidth = 0)   ret_as(WandX::CreatePen(PS_USERSTYLE, nWidth, rgb));
	static inline Pen CreateAlternate(COLORREF rgb, int nWidth = 0)   ret_as(WandX::CreatePen(PS_ALTERNATE, nWidth, rgb));
public:
	static inline Pen White() ret_as((HPEN)WandX::GetStockObject(WHITE_PEN));
	static inline Pen Black() ret_as((HPEN)WandX::GetStockObject(BLACK_PEN));
	static inline Pen Nu()  ret_as((HPEN)WandX::GetStockObject(NULL_PEN));
	static inline Pen DC()    ret_as((HPEN)WandX::GetStockObject(DC_PEN));
public: // Property - Log
	/* R */
public:
	using Super::operator=;
};
