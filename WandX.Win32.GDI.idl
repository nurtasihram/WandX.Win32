public: // Property - ICMProfile
	/* W */ inline auto &ICMProfile(const StringA &str) ret_to_self(WandX::SetICMProfile(self, const_cast<LPSTR>(str.c_str())));
	/* W */ inline auto &ICMProfile(const StringW &str) ret_to_self(WandX::SetICMProfile(self, const_cast<LPWSTR>(str.c_str())));
	template<bool IsUnicode = Native::IsUnicode>
	/* R */ inline StringX<IsUnicode> ICMProfile() const {
		DWORD len = 0;
		WandX::GetICMProfile(self, &len, (LPXSTR<IsUnicode>)O);
		StringX<IsUnicode> str((SizeT)len);
		WandX::GetICMProfile(self, O, str);
		return right_cast(str);
	}
