#pragma region Module
class Module {
protected:
	mutable HINSTANCE hInst = O;
	proxy_basetype(Module);
	Module(HINSTANCE h) : hInst(h) {}
	Module(const Module &m) : hInst(m.hInst) ret_to(m.hInst = O);
public:
	Module() : hInst(GetModuleHandle((LPCTSTR)O)) {}
	Module(Nu) {}
	Module(Module &m) : hInst(m) ret_to(m.hInst = O);
	Module(Module &&m) : hInst(m) ret_to(m.hInst = O);
	Module(LPCSTR lpModuleName) : hInst(Handle(lpModuleName)) {}
	Module(LPCWSTR lpModuleName) : hInst(Handle(lpModuleName)) {}
	~Module() ret_to(Free());
public:
	static inline Module Handle(LPCSTR lpModuleName) ret_as(WandX::GetModuleHandle(lpModuleName));
	static inline Module Handle(LPCWSTR lpModuleName) ret_as(WandX::GetModuleHandle(lpModuleName));
	static inline Module Library(LPCSTR lpLibFileName) ret_as(WandX::LoadLibrary(lpLibFileName));
	static inline Module Library(LPCWSTR lpLibFileName) ret_as(WandX::LoadLibrary(lpLibFileName));
//	static inline Module Load(LPCSTR lpModuleName, LPVOID lpParameterBlock = O) ret_as(LoadModule(lpModuleName, lpParameterBlock));
public:
	inline void Free() {
		if (hInst)
			WandX::FreeLibrary(hInst);
		hInst = O;
	}
public: // Property - Menu
	/* R */ inline CMenu Menu(LPCSTR lpszName) const ret_as(WandX::LoadMenu(self, lpszName));
	/* R */ inline CMenu Menu(LPCWSTR lpszName) const ret_as(WandX::LoadMenu(self, lpszName));
	/* R */ inline CMenu Menu(WORD wID) const ret_as(WandX::LoadMenu(self, MAKEINTRESOURCE(wID)));
public: // Property - Accelerators
	/* R */ inline CAccel Accelerators(LPCSTR lpszName) const ret_as(WandX::LoadAccelerators(self, lpszName));
	/* R */ inline CAccel Accelerators(LPCWSTR lpszName) const ret_as(WandX::LoadAccelerators(self, lpszName));
	/* R */ inline CAccel Accelerators(WORD wID) const ret_as(WandX::LoadAccelerators(self, MAKEINTRESOURCE(wID)));
public: // Property - Bitmap
	/* R */ inline CBitmap Bitmap(LPCSTR lpszName) const ret_as(WandX::LoadBitmap(self, lpszName));
	/* R */ inline CBitmap Bitmap(LPCWSTR lpszName) const ret_as(WandX::LoadBitmap(self, lpszName));
	/* R */ inline CBitmap Bitmap(WORD wID) const ret_as(WandX::LoadBitmap(self, MAKEINTRESOURCE(wID)));
public: // Property - Icon
	/* R */ inline CIcon Icon(LPCSTR lpszName) const ret_as(WandX::LoadIcon(self, lpszName));
	/* R */ inline CIcon Icon(LPCWSTR lpszName) const ret_as(WandX::LoadIcon(self, lpszName));
	/* R */ inline CIcon Icon(WORD wID) const ret_as(WandX::LoadIcon(self, MAKEINTRESOURCE(wID)));
public: // Property - Cursor
	/* R */ inline CCursor Cursor(LPCSTR lpszName) const ret_as(WandX::LoadCursor(self, lpszName));
	/* R */ inline CCursor Cursor(LPCWSTR lpszName) const ret_as(WandX::LoadCursor(self, lpszName));
	/* R */ inline CCursor Cursor(WORD wID) const ret_as(WandX::LoadCursor(self, MAKEINTRESOURCE(wID)));
public: // Property - String
	template<bool IsUnicode = Native::IsUnicode>
	inline StringX<IsUnicode> String(WORD wID) const {
		if constexpr (IsUnicode)
			 return StringW(wID);
		else return StringA(wID);
	}
	inline WandX::StringA StringA(WORD wID) const {
		auto len = StringW(wID).Length();
		WandX::StringA str(len);
		WandX::LoadString(self, wID, str, (int)len);
		return right_cast(str);
	}
	inline const WandX::StringW StringW(WORD wID) const {
		LPCWSTR lpString = O;
		int len = WandX::LoadString(self, wID, (LPWSTR)&lpString, 0);
		return CString(len, lpString);
	}
public: // Property - Symbol
	template<class AnyType>
	inline AnyType *Symbol(LPCSTR lpName) ret_as((AnyType *)::GetProcAddress(self, lpName));
public: // Property - FileName
	template<bool IsUnicode = Native::IsUnicode, SizeT MaxLen = MaxLenPath>
	/* R */ inline StringX<IsUnicode> FileName() const {
		StringX<IsUnicode> str(MaxLen);
		auto len = WandX::GetModuleFileName(self, str, (int)MaxLen);
		return right_cast(str.Resize(len));
	}
	template<SizeT MaxLen = MaxLenPath>
	/* R */ inline WandX::StringA FileNameA() const ret_as(FileName<false, MaxLen>());
	template<SizeT MaxLen = MaxLenPath>
	/* R */ inline WandX::StringW FileNameW() const ret_as(FileName<true, MaxLen>());
public:
	inline operator bool() const ret_as(hInst);
	inline operator HINSTANCE() const ret_as(hInst);
	inline operator LPARAM() const ret_as((LPARAM)hInst);
	inline auto &operator=(Module &m) ret_to_self(std::swap(hInst, m.hInst));
	inline auto &operator=(Module &&m) ret_to_self(std::swap(hInst, m.hInst));
	inline auto &operator=(const Module &m) const ret_to_self(std::swap(hInst, m.hInst));
public:
	static inline Module &Attach(HINSTANCE &hInst) ret_as(ref_cast<Module>(hInst));
	static inline const Module &Attach(const HINSTANCE &hInst) ret_as(ref_cast<const Module>(hInst));
};
using CModule = ProxyView<Module>;
#pragma endregion

inline Bitmap ClipBitmap(const Bitmap &bmp, WandX::Rect rc) {
	auto &&size = rc.size();
	Bitmap nBmp = Bitmap::Create(size).BitsPerPixel(bmp.Log().BitsPerPixel());
	DC srcDC = DC::CreateCompatible(), dstDC = DC::CreateCompatible();
	srcDC.Select(nBmp);
	dstDC.Select(bmp);
	srcDC.BltBit(0, size, dstDC);
	return nBmp;
}

