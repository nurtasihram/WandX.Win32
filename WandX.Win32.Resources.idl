		   String        = MFT_STRING       ,
		   Bitmap        = MFT_BITMAP       ,
		   BarBreak      = MFT_MENUBARBREAK ,
		   Break         = MFT_MENUBREAK    ,
		   OwnerDraw     = MFT_OWNERDRAW    ,
