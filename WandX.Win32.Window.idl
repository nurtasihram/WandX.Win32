


#pragma region Monitor
class Monitor {
	mutable HMONITOR hMonitor = O;
protected:
	proxy_basetype(Monitor);
	Monitor(HMONITOR h) : hMonitor(h) {}
	Monitor(const Monitor &m) = delete;
public:
	Monitor() {}
	Monitor(Nu) {}
public: // Property - Info
	/* R */ inline MonitorInfo Info() const ret_to(MonitorInfo mi; WandX::GetMonitorInfo(hMonitor, &mi), mi);
public: // Property - InfoEx
	template<bool IsUnicode = Native::IsUnicode>
	/* R */ inline MonitorInfoExX<IsUnicode> InfoEx() const ret_to(MonitorInfoExX<IsUnicode> mie; WandX::GetMonitorInfo<IsUnicode>(hMonitor, &mie), mie);
	/* R */ inline MonitorInfoExA InfoExA() const ret_as(InfoEx<false>());
	/* R */ inline MonitorInfoExW InfoExW() const ret_as(InfoEx<true>());
public:
	inline operator HMONITOR() const ret_as(hMonitor);
};
#pragma endregion

