#pragma region Misc

struct KEY_FLAGS {
	Int16U wScanCode : 8;
	Int16U bExtend : 1;
	Int16U ___reserved : 4;
	Int16U bContext : 1;
	Int16U bPrevious : 1;
	Int16U bTranslated : 1;
};

class WindowProcedure {
	WNDPROC pfnWndProc = O;
public:
	WindowProcedure() {}
	WindowProcedure(WNDPROC pfnWndProc) : pfnWndProc(pfnWndProc) {}
public:
	template<bool IsUnicode = Native::IsUnicode>
	inline LRESULT Call(HWND hWnd, UINT Msg, WPARAM wParam, LPARAM lParam) const ret_as(CallWindowProc<IsUnicode>(pfnWndProc, hWnd, Msg, wParam, lParam));
public:
	inline LRESULT operator()(HWND hWnd, UINT Msg, WPARAM wParam, LPARAM lParam) const ret_as(Call(hWnd, Msg, wParam, lParam));
public:
	inline operator bool() const ret_as(pfnWndProc);
	inline operator WNDPROC() const ret_as(pfnWndProc);
};
using WndProc = WindowProcedure;




#pragma endregion

#pragma region WindowClass
using CStyle = ClassStyle;
template<class WNDCLASS, class AnyChild>
	requires IsSame<WNDCLASS, WNDCLASSA> || IsSame<WNDCLASS, WNDCLASSW> ||
			 IsSame<WNDCLASS, WNDCLASSEXA> || IsSame<WNDCLASS, WNDCLASSEXW> 
class WindowClassBase : public StructShim<WNDCLASS>,
	public ExtendShim<WindowClassBase<WNDCLASS, AnyChild>, AnyChild> {
	using LPCTSTR = decltype(WNDCLASS::lpszClassName);
	using String = StringX<IsCharW<LPCTSTR>>;
public:
	using Super = StructShim<WNDCLASS>;
	using Child = AnyChild;
	using Style = CStyle;
public:
	WindowClassBase() {}
	WindowClassBase(const WNDCLASS &wc) : Super(wc) {}
public: // Property - Styles
	/* W */ inline auto&Styles(Style style) ret_to_child(self->style = style.yield());
	/* R */ inline auto Styles() const ret_as(ref_cast<Style>(self->style));
public: // Property - WndProc
	/* W */ inline auto&WndProc(WNDPROC lpfnWndProc) ret_to_child(self->lpfnWndProc = lpfnWndProc);
proxy_prop_get(WndProc,lpfnWndProc,WandX::WndProc);
public: // Property - ClsExtra
	/* W */ inline auto&ClsExtra(int cbClsExtra) ret_to_child(self->cbClsExtra = cbClsExtra);
proxy_prop_get(ClsExtra,cbClsExtra,auto);
public: // Property - WndExtra
	/* W */ inline auto&WndExtra(int cbWndExtra) ret_to_child(self->cbWndExtra = cbWndExtra);
proxy_prop_get(WndExtra,cbWndExtra,auto);
public: // Property - Module
	/* W */ inline auto&Module(HINSTANCE hModule) ret_to_child(self->hInstance = hModule);
proxy_prop_get(Module,hInstance,CModule);
public: // Property - Icon
	/* W */ inline auto&Icon(CIcon icon) ret_to_child(self->hIcon = icon);
	/* W */ inline auto&Icon(LPCTSTR lpszName) ret_to_child(self->hIcon = Module()->Icon(lpszName));
	/* W */ inline auto&Icon(WORD wID) ret_to_child(self->hIcon = Module()->Icon(wID));
proxy_prop_get(Icon,hIcon,CIcon);
public: // Property - Cursor
	/* W */ inline auto&Cursor(CCursor cursor) ret_to_child(self->hCursor = cursor);
	/* W */ inline auto&Cursor(LPCTSTR lpszName) ret_to_child(self->hCursor = Module()->Cursor(lpszName));
	/* W */ inline auto&Cursor(WORD wID) ret_to_child(self->hCursor = Module()->Cursor(wID));
proxy_prop_get(Cursor,hCursor,CCursor);
public: // Property - Background
	/* W */ inline auto&Background(CBrush brush) ret_to_child(self->hbrBackground = brush);
proxy_prop_get(Background,hbrBackground,CBrush);
public: // Property - Menu
	/* W */ inline auto&Menu(LPCTSTR lpszMenuName) ret_to_child(self->lpszMenuName = lpszMenuName);
	/* W */ inline auto&Menu(WORD wID) ret_to_child(self->lpszMenuName = (LPCTSTR)MAKEINTRESOURCE(wID));
public: // Property - MenuName
	template<SizeT MaxLen = MaxLenPath>
	/* R */ inline const String MenuName() const ret_as(CString(self->lpszMenuName, MaxLen));
public: // Property - Name
	/* W */ inline auto&Name(LPCTSTR lpszClassName) ret_to_child(self->lpszClassName = lpszClassName);
	template<SizeT MaxLen = MaxLenClass>
	/* R */ inline String Name() const {
		auto_stringx(fmt, "#%d");
		if (!self->lpszClassName)
			return O;
		if (IS_INTRESOURCE(self->lpszClassName))
			return format(fmt, (ATOM)(ULONG_PTR)self->lpszClassName);
		return CString(self->lpszClassName, MaxLen);
	}
public: // Property - Atom
	/* W */ inline auto&Atom(ATOM classAtom) ret_to_child(self->lpszClassName = (LPCTSTR)MAKEINTRESOURCE(classAtom));
	/* R */ inline ATOM Atom() const ret_as(IS_INTRESOURCE(self->lpszClassName) ? (ATOM)(ULONG_PTR)self->lpszClassName : 0);
public:
	inline ATOM Register() const ret_as(WandX::RegisterClass(&self));
	inline void Unregister() const ret_as(WandX::UnregisterClass(self->lpszClassName, self->hInstance));
};
template<bool IsUnicode>
class WindowClassX : public WindowClassBase<structx(WNDCLASS), WindowClassX<IsUnicode>> {
	using WNDCLASS = structx(WNDCLASS);
public:
	using Super = WindowClassBase<WNDCLASS, WindowClassX>;
public:
	WindowClassX() {}
	WindowClassX(const WindowClassX &wc) : Super(wc) {}
	WindowClassX(const WNDCLASS &wc) : Super(wc) {}
};
using WindowClass = WindowClassX<IsUnicode>;
using WindowClassA = WindowClassX<false>;
using WindowClassW = WindowClassX<true>;
template<bool IsUnicode>
class WindowClassExX : public WindowClassBase<structx(WNDCLASSEX), WindowClassExX<IsUnicode>> {
	using_structx(WNDCLASSEX);
	using LPCTSTR = LPCXSTR<IsUnicode>;
	using String = StringX<IsUnicode>;
public:
	using Super = WindowClassBase<WNDCLASSEX, WindowClassExX>;
public:
	WindowClassExX() ret_to(self->cbSize = (int)sizeof(WNDCLASSEX));
	WindowClassExX(const WindowClassExX &wc) : Super(wc) {}
	WindowClassExX(const WNDCLASSEX &wc) : Super(wc) {}
public: // Property - IconSmall
proxy_prop_set(IconSmall, HICON, hIconSm);
	/* W */ inline auto &IconSmall(LPCTSTR lpszName) ret_to_self(self->hIconSm = this->Module()->Icon(lpszName));
	/* W */ inline auto &IconSmall(WORD wID) ret_to_self(self->hIconSm = this->Module()->Icon(wID));
proxy_prop_get(IconSmall,hIconSm,CIcon);
};
using WindowClassEx = WindowClassExX<IsUnicode>;
using WindowClassExA = WindowClassExX<false>;
using WindowClassExW = WindowClassExX<true>;
#pragma endregion

#pragma region CreateStruct
template<bool IsUnicode, class Style = WStyle, class StyleEx = WStyleEx>
class CreateStructX : public StructShim<structx(CREATESTRUCT)> {
	using_structx(CREATESTRUCT);
	using_structx(WNDCLASS);
	using_structx(WNDCLASSEX);
	using LPCTSTR = LPCXSTR<IsUnicode>;
	using String = StringX<IsUnicode>;
public:
	using Super = StructShim<CREATESTRUCT>;
public:
	CreateStructX() {}
	CreateStructX(const CREATESTRUCT &cs) : Super(cs) {}
public: // Property - Param
proxy_prop_set(Param, LPVOID, lpCreateParams);
	template<class AnyType = void>
	/* R */ inline AnyType *Param() const ret_as((AnyType *)self->lpCreateParams);
	proxy_prop(Module,hInstance,HINSTANCE,CModule);
	proxy_prop(Menu,hMenu,HMENU,CMenu);
public: // Property - ID
	/* W */ inline auto &ID(UINT uID) ret_to_self(self->hMenu = small_cast<HMENU>(uID));
	/* R */ inline UINT ID() const ret_as(small_cast<HMENU>(self->hMenu));
public: // Property - Parent
proxy_prop_set(Parent, HWND, hwndParent);
	template<class AnyChild = void>
	/* R */ inline WindowShim<AnyChild> Parent() ret_as(self->hwndParent);
	template<class AnyChild = void>
proxy_prop_get(Parent,hwndParent,CWindowShim<AnyChild>);
public: // Property - Styles
	proxy_prop_set(Styles,style,Style);
	/* R */ inline Style Styles() const ret_as(ref_cast<Style>(self->style));
public: // Property - Caption
proxy_prop_set(Caption,lpszName,LPCTSTR);
	/* R */ inline String Caption() const ret_as(CString(self->lpszName, MaxLenTitle));
public: // Property - Class
proxy_prop_set(Class,lpszClass,LPCTSTR);
	/* W */ inline auto&Class(ATOM classAtom) ret_to_self(self->lpszClass = (LPCTSTR)MAKEINTRESOURCE(classAtom));
	/* W */ inline auto&Class(const WNDCLASS &wc) ret_to_self(self->lpszClass = wc.lpszClassName);
public: // Property - ClassName
proxy_prop_set(ClassName,lpszClass,LPCTSTR);
	template<SizeT MaxLen = MaxLenClass>
	/* R */ inline String ClassName() const {
		if (!self->lpszClass)
			return O;
		if (IS_INTRESOURCE(self->lpszClass))
			return format("#%d", (ATOM)(ULONG_PTR)self->lpszClass);
		return CString(self->lpszClass, MaxLen);
	}
public: // Property - ClassAtom
	/* W */ inline auto&ClassAtom(ATOM classAtom) ret_to_self(self->lpszClass = (LPCTSTR)MAKEINTRESOURCE(classAtom));
	/* R */ inline ATOM ClassAtom() const ret_as(IS_INTRESOURCE(self->lpszClass) ? (ATOM)(ULONG_PTR)self->lpszClass : 0);
public: // Property - StylesEx
	proxy_prop_set(StylesEx,dwExStyle,StyleEx);
	/* R */ inline StyleEx StylesEx() const ret_as(ref_cast<StyleEx>(self->dwExStyle));
public: // Property - Size
	/* W */ inline auto &Size(WandX::Size size) ret_to_self(self->cx = size.cx, self->cy = size.cy);
	/* R */ inline WandX::Size Size() const ret_as({ self->cx, self->cy });
public: // Property - Position
	/* W */ inline auto  &Position(Point pos) ret_to_self(self->x = pos.x, self->y = pos.y);
	/* R */ inline Point Position() const ret_as({ self->x, self->y });
public: // Property - Rect
	/* W */ inline auto &Rect(WandX::Rect r) ret_to_self(Size(r), Position(r.left_top()));
	/* R */ inline WandX::Rect Rect() const ret_as(WandX::Rect::left_top(Position(), Size()));
public: // Property - ClientRect
	/* W */ inline auto&ClientRect(WandX::Rect rc) ret_to_self(WandX::AdjustWindowRect(&rc, self->style, self->hMenu, self->dwExStyle), Rect(rc));
	/* W */ inline auto&ClientRect(WandX::Rect rc, UINT dpi) ret_to_self(WandX::AdjustWindowRectForDpi(&rc, self->style, self->hMenu, self->dwExStyle, dpi), Rect(rc));
public: // Property - ClientSize
	/* W */ inline auto&ClientSize(WandX::Size sz) ret_as(ClientRect(WandX::Rect::left_top(Position(), sz)));
	/* W */ inline auto&ClientSize(WandX::Size sz, UINT dpi) ret_as(ClientRect(WandX::Rect::left_top(Position(), sz), dpi));
public:
	template <class AnyChild = void>
	inline WindowShim<AnyChild> Create() const ret_as(
		WandX::CreateWindow(
			self->dwExStyle, self->lpszClass, self->lpszName, self->style,
			self->x, self->y, self->cx, self->cy,
			self->hwndParent, self->hMenu, self->hInstance,
			self->lpCreateParams));
	template <class AnyChild = void>
	inline WindowShim<AnyChild> CreateMDI() const ret_as(WandX::CreateMDIWindow(
		self->dwExStyle, self->lpszClass, self->lpszName, self->style,
		self->x, self->y, self->cx, self->cy,
		self->hwndParent, self->hMenu, self->hInstance,
		self->lpCreateParams));
};
using CreateStruct = CreateStructX<IsUnicode>;
using CreateStructA = CreateStructX<false>;
using CreateStructW = CreateStructX<true>;
#pragma endregion

