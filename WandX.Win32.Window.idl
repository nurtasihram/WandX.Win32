template<bool IsUnicode = Native::IsUnicode>
class WindowIClassX {
	mutable HWND hWnd;
	class Word {
		friend class WindowIClassX;
		mutable HWND hWnd;
		mutable int nIndex;
		Word(HWND hWnd, int nIndex) : hWnd(hWnd), nIndex(nIndex) {}
	public:
		inline operator WORD() const ret_as(WandX::GetClassWord(hWnd, nIndex));
		inline void operator=(WORD word) ret_to(WandX::SetClassWord(hWnd, nIndex, word));
	};
	class Long {
		friend class WindowIClassX;
		mutable HWND hWnd;
		mutable int nIndex;
		Long(HWND hWnd, int nIndex) : hWnd(hWnd), nIndex(nIndex) {} 
	public:
		inline operator LONG_PTR() const ret_as(WandX::GetClassLongPtr<IsUnicode>(hWnd, nIndex));
		template<class AnyType>
		inline operator AnyType() const ret_as(big_cast<AnyType>(WandX::GetClassLongPtr<IsUnicode>(hWnd, nIndex)));
		inline void operator=(LONG_PTR dwNewLong) ret_to(WandX::GetClassLongPtr<IsUnicode>(hWnd, nIndex, dwNewLong));
		template<class AnyType>
		inline void operator=(AnyType dwNewLong) ret_to(WandX::GetClassLongPtr<IsUnicode>(hWnd, nIndex, small_cast<AnyType>(dwNewLong)));
	};
private:
	template<class>
	friend class WindowBase;
	WindowIClassX(HWND hWnd) : hWnd(hWnd) {}
	WindowIClassX(const WindowIClassX &) = delete;
public:
	WindowIClassX(WindowIClassX &wic) : hWnd(wic.hWnd) {}
public: // Property - Words
	/* W */ inline Word Words(int nIndex) ret_as({ hWnd, nIndex });
	/* W */ inline const Word Words(int nIndex) const ret_as({ hWnd, nIndex });
public: // Property - Longs
	/* W */ inline Long Longs(int nIndex) ret_as({ hWnd, nIndex });
	/* W */ inline const Long Longs(int nIndex) const ret_as({ hWnd, nIndex });
public: // Property - Styles
	/* W */ inline auto&Styles(ClassStyle style) ret_to_self(Longs(GCL_STYLE) = style.yield());
	/* R */ inline auto Styles() const ret_as((ClassStyle)Longs(GCL_STYLE));
public: // Property - WndProc
	/* W */ inline auto&WndProc(WNDPROC lpfnWndProc) ret_to_self(Longs(GCLP_WNDPROC) = lpfnWndProc);
//	/* R */ inline WandX::WndProc WndProc() const ret_as({ hWnd, (WNDPROC)Longs(GCLP_WNDPROC)));
public: // Property - ClsExtra
	/* W */ inline auto&ClsExtra(int cbClsExtra) ret_to_self(Longs(GCL_CBCLSEXTRA) = cbClsExtra);
	/* R */ inline auto ClsExtra() const ret_as((int)Longs(GCL_CBCLSEXTRA));
public: // Property - WndExtra
	/* W */ inline auto&WndExtra(int cbWndExtra) ret_to_self(Longs(GCL_CBWNDEXTRA) = cbWndExtra);
	/* R */ inline auto WndExtra() const ret_as((int)Longs(GCL_CBWNDEXTRA));
public: // Property - Module
	/* W */ inline auto&Module(HINSTANCE hModule) ret_to_self(Longs(GCLP_HMODULE) = hModule);
	/* R */ inline CModule Module() const ret_as((HMODULE)Longs(GCLP_HMODULE));
public: // Property - Icon
	/* W */ inline auto &Icon(CIcon icon) ret_to_self(Longs(GCLP_HICON) = icon);
	/* R */ inline CIcon Icon() const ret_as((HICON)Longs(GCLP_HICON));
public: // Property - Cursor
	/* W */ inline auto   &Cursor(CCursor cursor) ret_to_self(Longs(GCLP_HCURSOR) = cursor);
	/* R */ inline CCursor Cursor() const ret_as((HCURSOR)Longs(GCLP_HCURSOR));
public: // Property - Background
	/* W */ inline auto  &Background(CBrush brush) ret_to_self(Longs(GCLP_HBRBACKGROUND) = brush);
	/* R */ inline CBrush Background() const ret_as((HBRUSH)Longs(GCLP_HBRBACKGROUND));
public: // Property - Menu
	/* W */ inline auto&Menu(LPCTSTR lpszName) ret_to_self(Longs(GCLP_MENUNAME) = lpszName);
	/* W */ inline auto&Menu(WORD wID) ret_to_self(Longs(GCLP_MENUNAME) = (LPCTSTR)MAKEINTRESOURCE(wID));
// 	template<SizeT MaxLen = MaxLenPath>
//	/* R */ inline const String MenuName() const ret_as(CString((LPCTSTR)Longs(GCLP_MENUNAME), MaxLen));
public: // Property - Name
	template<SizeT MaxLen = MaxLenClass>
	/* R */ inline StringX<IsUnicode> Name() const {
		StringX<IsUnicode> str(MaxLen);
		auto len = WandX::GetClassName(hWnd, str, (int)MaxLen);
		return right_cast(str.Resize(len));
	}
public: // Property - Atom
	/* W */ inline auto &Atom(ATOM classAtom) ret_to_self(Words(GCW_ATOM) = classAtom);
	/* R */ inline CAtom Atom() const ret_as(Words(GCW_ATOM));
public:
	inline operator WindowClassX<IsUnicode>() const ret_to(WindowClassX<IsUnicode> wc; WandX::GetClassInfo(Module(), (ATOM)Atom(), &wc), wc);
	inline auto&operator=(const WindowIClassX &wic) ret_to_self(hWnd = wic.hWnd);
};
using WindowIClass = WindowIClassX<IsUnicode>;
using WindowIClassA = WindowIClassX<false>;
using WindowIClassW = WindowIClassX<true>;
#pragma endregion

template<class AnyChild>
class WindowBase : 
	public ExtendShim<WindowBase<AnyChild>, AnyChild> {
	template<bool, class, class>
	friend class CreateStructX;
	mutable HWND hWnd = O;
public:
	using Child = Chain<WindowBase, AnyChild>;
	using Super = WindowBase;
	using Shim = WindowShim<AnyChild>;
	using Style = WStyle;
	using StyleEx = WStyleEx;
protected:
	proxy_basetype(WindowBase);
	WindowBase(HWND h) : hWnd(h) {}
	WindowBase(const WindowBase &w) : hWnd(w.hWnd) ret_to(w.hWnd = O);
public:
	WindowBase(Nu) {}
	WindowBase() {}
	WindowBase(WindowBase &w) : hWnd(w.hWnd) ret_to(w.hWnd = O);
	WindowBase(WindowBase &&w) : hWnd(w.hWnd) ret_to(w.hWnd = O);
	~WindowBase() ret_to(Delete());
public:
	//static inline WindowShim<AnyClass> Find(LPCSTR lpName, LPCSTR lpClass) ret_as(WandX::FindWindow(lpClass, lpName));
	//static inline WindowShim<AnyClass> Find(LPCWSTR lpName, LPCWSTR lpClass) ret_as(WandX::FindWindow(lpClass, lpName));
	static inline Shim Find(LPCSTR lpName) ret_as(WandX::FindWindow((LPCSTR)(ULONG_PTR)WindowBase::_ClassAtom, lpName));
	static inline Shim Find(LPCWSTR lpName) ret_as(WandX::FindWindow((LPCWSTR)(ULONG_PTR)WindowBase::_ClassAtom, lpName));
	static inline Shim Active() ret_as(WandX::GetActiveWindow());
	static inline Shim Desktop() ret_as(WandX::GetDesktopWindow());
	static inline Shim Foreground() ret_as(WandX::GetForegroundWindow());
	static inline void Foreground(HWND hWnd) ret_to(WandX::SetForegroundWindow(hWnd));
public:
	inline void Delete() {
		if (self)
			Send(WM_DESTROY);
	}
public: // MsgBox
	inline int MsgBox(LPCSTR lpCaption, LPCSTR lpText = O, MB uType = MB::Ok) const ret_as(WandX::MsgBox(lpCaption, lpText, uType, self));
	inline int MsgBox(LPCWSTR lpCaption, LPCWSTR lpText = O, MB uType = MB::Ok) const ret_as(WandX::MsgBox(lpCaption, lpText, uType, self));
	inline int MsgBox(LPCSTR lpCaption, const Exception &err) const ret_as(WandX::MsgBox(lpCaption, err, self));
	inline int MsgBox(LPCWSTR lpCaption, const Exception &err) const ret_as(WandX::MsgBox(lpCaption, err, self));
public: // Show
	inline auto&Show(Shows nShow)     ret_to_child(WandX::ShowWindow(self, nShow.yield()));
	inline auto&Hide()             ret_as(Show(Shows::Hide));
	inline auto&Normal()           ret_as(Show(Shows::Normal));
	inline auto&ShowNormal()       ret_as(Show(Shows::ShowNormal));
	inline auto&ShowMinimized()    ret_as(Show(Shows::ShowMinimized));
	inline auto&ShowMaximized()    ret_as(Show(Shows::ShowMaximized));
	inline auto&ShowNoActivate()   ret_as(Show(Shows::ShowNoActivate));
	inline auto&Show()             ret_as(Show(Shows::Show));
	inline auto&Maximize()         ret_as(Show(Shows::Maximize));
	inline auto&Minimize()         ret_as(Show(Shows::Minimize));
	inline auto&ForceMinimize()    ret_as(Show(Shows::ForceMinimize));
	inline auto&ShowMinNoActive()  ret_as(Show(Shows::ShowMinNoActive));
	inline auto&ShowDefault()      ret_as(Show(Shows::ShowDefault));
	inline auto&ShowNA()           ret_as(Show(Shows::ShowNA));
	inline auto&Restore()          ret_as(Show(Shows::Restore));
	inline auto&Max()              ret_as(Show(Shows::Max));
public: // Flash
	inline bool Flash(bool bInvert) const ret_as(WandX::FlashWindow(self, bInvert));
	inline bool Flash(FlashInfo fi) const ret_as(WandX::FlashWindow(&fi));
public: // Focus
	inline void Focus() const ret_to(SetFocus(self));
	inline bool Focussed() const ret_as(GetFocus() == self);
public: // Capture
	inline void Capture() const ret_to(WandX::SetCapture(self));
	inline bool Captured() const ret_as(WandX::GetCapture() == self);
public: // Rect & Point
	inline auto Screen2Client(Point pt) const ret_to(WandX::ScreenToClient(self, &pt), pt);
	inline auto Client2Screen(Point pt) const ret_to(WandX::ClientToScreen(self, &pt), pt);
	inline auto Log2Phy(Point pt) const ret_to(WandX::LogicalToPhysicalPoint(self, &pt), pt);
	inline auto Phy2Log(Point pt) const ret_to(WandX::PhysicalToLogicalPoint(self, &pt), pt);
	inline auto Logical2Physical(Point pt) const ret_to(WandX::LogicalToPhysicalPoint(self, &pt), pt);
	inline auto Physical2Logical(Point pt) const ret_to(WandX::PhysicalToLogicalPoint(self, &pt), pt);
	inline auto Log2PhyDPI(Point pt) const ret_to(WandX::LogicalToPhysicalPointForPerMonitorDPI(self, &pt), pt);
	inline auto Phy2LogDPI(Point pt) const ret_to(WandX::PhysicalToLogicalPointForPerMonitorDPI(self, &pt), pt);
	inline auto Logical2PhysicalDPI(Point pt) const ret_to(WandX::LogicalToPhysicalPointForPerMonitorDPI(self, &pt), pt);
	inline auto Physical2LogicalDPI(Point pt) const ret_to(WandX::PhysicalToLogicalPointForPerMonitorDPI(self, &pt), pt);
	inline auto AdjRect(WandX::Rect rc) const ret_to(WandX::AdjustWindowRect(&rc, Styles().yield(), this->Menu(), this->StylesEx().yield()), rc);
	inline auto AdjustRect(WandX::Rect rc) const ret_to(WandX::AdjustWindowRect(&rc, Styles().yield(), this->Menu(), this->StylesEx().yield()), rc);
	inline auto AdjRectDPI(WandX::Rect rc, UINT dpi) const ret_to(WandX::AdjustWindowRectForDpi(&rc, Styles().yield(), this->Menu(), this->StylesEx().yield(), dpi), rc);
	inline auto AdjustRectDPI(WandX::Rect rc, UINT dpi) const ret_to(WandX::AdjustWindowRectForDpi(&rc, Styles().yield(), this->Menu(), this->StylesEx().yield(), dpi), rc);
public: // Position
	inline void BringToTop() const ret_to_child(WandX::BringWindowToTop(self));
	inline void Move(WandX::Rect rc, bool bRedraw = true) const ret_to(WandX::MoveWindow(self, rc.top, rc.left, rc.xsize(), rc.ysize(), bRedraw));
public: // Timer
	inline auto SetTimer(UINT uElapse, UINT_PTR nIDEvent = 0, TIMERPROC lpTimerFunc = O) ret_as(WandX::SetTimer(self, nIDEvent, uElapse, lpTimerFunc));
	inline void KillTimer(UINT_PTR nIDEvent) ret_to(WandX::KillTimer(self, nIDEvent));
public: // Touch & Mouse
	inline void RegisterTouch(bool bFine = true, bool bWantPalm = false) ret_to(WandX::RegisterTouchWindow(self, (bFine * TWF_FINETOUCH) | (bWantPalm * TWF_WANTPALM)));
	inline void UnregisterTouch() ret_to(WandX::UnregisterTouchWindow(self));
	inline TrackMouseEventBox TrackMouse() const ret_as((HWND)self);
public: // Draw & Paint
	inline void Update() ret_to(WandX::UpdateWindow(self));
	inline void Validate(LPCRECT lpRect = O) const ret_to(WandX::ValidateRect(self, lpRect));
	inline void Invalidate(LPCRECT lpRect = O, bool fErase = false) const ret_to(WandX::InvalidateRect(self, lpRect, fErase));
	inline void LockUpdate() const ret_to(WandX::LockWindowUpdate(self));
	//inline PaintBox BeginPaint() ret_as((HWND)self);
public: // Child & Parent
	inline bool HasChild(HWND hWnd) ret_as(WandX::IsChild(self, hWnd));
public: // Message Senders
	template<class RetType = LRESULT, class MsgType = UINT, class WParam = WPARAM, class LParam = LPARAM>
	inline RetType Send(MsgType msgid, WParam wParam = 0, LParam lParam = 0) const ret_as(big_cast<RetType>(WandX::SendMessage(self, (UINT)(msgid), small_cast<WPARAM>(wParam), small_cast<LPARAM>(lParam))));
	//template<class WParam = WPARAM, class LParam = LPARAM>
	//inline auto&SendTimeout(UINT msgid, WParam wParam = 0, LParam lParam = 0) {
	//	WandX::SendMessageTimeout(self, msgid, wParam, lParam, )
	//}
	template<class MsgType = UINT, class WParam = WPARAM, class LParam = LPARAM>
	inline auto&Post(MsgType msgid, WParam wParam = 0, LParam lParam = 0) const ret_to_child(WandX::PostMessage(self, reuse_cast<UINT>(msgid), reuse_cast<WPARAM>(wParam), reuse_cast<LPARAM>(lParam)));

#pragma region Enum
public:
	using FnEnumWindow = Lambda<bool(HWND)>;
private:
	static BOOL EnumWindowProc(HWND hWnd, LPARAM lParam) ret_as((*(FnEnumWindow *)lParam)(hWnd));
public:
	template<class AnyFunc>
	static inline void Enum(AnyFunc fnEnum) {
		FnEnumWindow fnEnumWindows([&](HWND hWnd) {
			if constexpr (static_compatible<AnyFunc, bool(HWND)>)
				return fnEnum(hWnd);
			else {
				misuse_assert((static_compatible<AnyFunc, void(HWND)>),
							  "Enumeration function must compatible to bool(HWND) or void(HWND)");
				fnEnum(hWnd);
				return true;
			}
		});
		WandX::EnumWindows(EnumWindowProc, (LPARAM)std::addressof(fnEnumWindows));
	}
	template<class AnyFunc>
	inline void EnumChild(AnyFunc fnEnum) {
		FnEnumWindow fnEnumChildren([&](HWND hWnd) {
			if constexpr (static_compatible<AnyFunc, bool(HWND)>)
				return fnEnum(hWnd);
			else {
				misuse_assert((static_compatible<AnyFunc, void(HWND)>),
							  "Enumeration function must compatible to bool(HWND) or void(HWND)");
				fnEnum(hWnd);
				return true;
			}
		});
		EnumChildWindows(self, EnumWindowProc, (LPARAM)std::addressof(fnEnumChildren));
	}
#pragma endregion

#pragma region Message Procedure Reflect System
protected: // Default Message Procedure
	ref_member(DefProc);
	static LRESULT CallDefProc(HWND hWnd, UINT msgid, WPARAM wParam, LPARAM lParam) {
		if constexpr (member_DefProc_of<Child>::is_addressable) {
			misdef_assert((!std::is_member_pointer_v<decltype(&Child::DefProc)>),
						  "DefProc must be a static method.");
			using tfn_WndProc = LRESULT(HWND, UINT, WPARAM, LPARAM);
			misdef_assert((member_DefProc_of<Child>::template compatible_to<tfn_WndProc>),
						  "DefProc must be compatible to LRESULT(HWND, UINT, WPARAM, LPARAM)");
			return Child::DefProc(hWnd, msgid, wParam, lParam);
		}
		else return WandX::DefWindowProc(hWnd, msgid, wParam, lParam);
	}
public: // Reflectors management
	class Reflectors {
		Child *pChild;
	public:
		Reflectors(Child *pChild) : pChild(pChild) {}
#define CALL(name) pChild->On##name
#define SEND(ret, msgid, wparam, lparam) pChild->On##name(wparam, lparam)
#define MSG_TRANS(msgid, ret, name, argslist, args, send, call) \
		private: ref_member(On##name); \
		public: static constexpr bool User##name = member_On##name##_of<Child>::is_addressable; \
		inline LRESULT CallOn##name argslist { \
			using fn_type = ret argslist; \
			if constexpr (member_On##name##_of<Child>::template compatible_to<ret()>) \
				if constexpr (std::is_void_v<ret>) \
					 ret_as((pChild->On##name(), 0L)) \
				else ret_as((LRESULT)pChild->name()) \
			elif constexpr (member_On##name##_of<Child>::template compatible_to<LRESULT()>) \
				ret_as(pChild->On##name()) \
			elif constexpr (member_On##name##_of<Child>::template compatible_to<void(WPARAM, LPARAM)>) \
				ret_as((send, 0L)) \
			elif constexpr (member_On##name##_of<Child>::template compatible_to<LRESULT(WPARAM, LPARAM)>) \
				ret_as(send) \
			elif constexpr (member_On##name##_of<Child>::template compatible_to<fn_type>) { \
				misdef_assert((member_On##name##_of<Child>::template compatible_to<fn_type>), \
							  "Member On" #name " must be a method compatible to " #ret #argslist ", " #ret "(), void(WPARAM, LPARAM) or LRESULT(WPARAM, LPARAM)" ); \
				ret_as(pChild->On##name args); \
			} \
		}
#include "wx__msg.inl"
	public:
		inline operator bool() const ret_as(pChild);
	};
protected: // Message Procedure
	ref_member(Callback);
	static LRESULT CALLBACK MainProc(HWND hWnd, UINT msgid, WPARAM wParam, LPARAM lParam) {
		auto&Wnd = WindowBase::Attach(hWnd);
		auto pChild = Wnd.UserData<Child *>();
	retry:
		try {
			switch (msgid) {
				case WM_NCCREATE: {
					auto lpCreate = (LPCREATESTRUCT)lParam;
					pChild = (Child *)lpCreate->lpCreateParams;
					Wnd.UserData(pChild);
					(*(WindowBase *)pChild).hWnd = hWnd;
					break;
				}
				case WM_COMMAND:
					if (auto wnd = ref_cast<Window>(lParam))
						wnd.Send(WM_USER + (UINT)HIWORD(wParam));
					break;
			}
			if (Reflectors ref = pChild) {
				switch (msgid) {
					case WM_NULL:
						break;
#define CALL(name) ref.CallOn##name
#define MSG_TRANS(msgid, ret, name, argslist, args, send, call) \
					case msgid: \
						if constexpr (Reflectors::User##name) { \
							return call; \
						} break;
#include "wx__msg.inl"
				}
			}
			if constexpr (member_Callback_of<Child>::is_addressable) {
				misdef_assert(member_Callback_of<Child>::template compatible_to<LRESULT(WPARAM, LPARAM)>, 
							  "Member Callback must be a method compatible to LRESULT(WPARAM, LPARAM)");
				return pChild->Callback(msgid, wParam, lParam);
			}
		} catch (MSG msg) {
			if (msg.message)
				return CallDefProc(msg.hwnd, msg.message, msg.wParam, msg.lParam);
		} catch (Exception err) {
			MsgException msgErr{ err, Msg{ hWnd, msgid, wParam, lParam } };
			if (Catch(pChild, msgErr))
				goto retry;
			return Final(pChild, msgErr);
		}
		return CallDefProc(hWnd, msgid, wParam, lParam);
	}
protected: // Default Message Definitions
	inline void OnDestroy() ret_to(WandX::PostQuitMessage(0));
protected: // Message Procedure Exception System
	ref_member(OnCatch);
	static inline wx_answer Catch(Child *pChild, const MsgException &err) {
		if constexpr (member_OnCatch_of<AnyChild>::template compatible_to<wx_answer(MsgException)>)
			ret_as(pChild->OnCatch(err))
		elif constexpr (member_OnCatch_of<AnyChild>::template compatible_to<wx_answer()>)
			ret_as(pChild->OnCatch())
		elif constexpr (member_OnCatch_of<AnyChild>::template compatible_to<void(MsgException)>)
			ret_as((pChild->OnCatch(err), false))
		elif constexpr (member_OnCatch_of<AnyChild>::template compatible_to<void()>)
			ret_as((pChild->OnCatch(), false))
		else {
			misdef_assert(!member_OnCatch_of<AnyChild>::is_addressable,
						  "Member OnCatch must be compatible to wx_answer(Exception), wx_answer(), void(MsgException) or void()");
			switch (WandX::MsgBox(T("Window Error"), err, err.Msg().Window())) {
				case IDRETRY:
					wx_answer_retry;
				case IDIGNORE:
					wx_answer_ignore;
				case IDABORT:
					break;
			}
			wx_answer_abort(err);
		}
	}
	ref_member(OnFinal);
	static inline LRESULT Final(Child *pChild, const MsgException &err) {
		if constexpr (member_OnFinal_of<AnyChild>::template compatible_to<LRESULT(MsgException)>)
			ret_as(pChild->OnFinal(err))
		elif constexpr (member_OnFinal_of<AnyChild>::template compatible_to<LRESULT()>)
			ret_as(pChild->OnFinal())
		elif constexpr (member_OnFinal_of<AnyChild>::template compatible_to<void(MsgException)>)
			ret_as((pChild->OnFinal(err), -1))
		elif constexpr (member_OnFinal_of<AnyChild>::template compatible_to<void()>)
			ret_as((pChild->OnFinal(), -1))
		else {
			misdef_assert(!member_OnFinal_of<AnyChild>::is_addressable,
						  "Member OnFinal must be compatible to LRESULT(MsgException), LRESULT(), void(MsgException), void()");
			ret_as(-3)
		}
	}
public:
	class CallPack {
		HWND hwnd;
	public:
		CallPack(HWND hwnd) : hwnd(hwnd) {}
#define SEND(ret, msgid, wparam, lparam) \
			(ret)(CallDefProc(hwnd, msgid, wparam, lparam))
#define MSG_TRANS(msgid, ret, name, argslist, args, send, call) \
			inline ret name argslist ret_as(send);
#include "wx__msg.inl"
	};
	inline CallPack DefProcCall() ret_as((HWND)self);
#pragma endregion

#pragma region Class Management
protected:
	static ATOM _ClassAtom;
	ref_member(CClassNameA);
	ref_member(CClassNameW);
public:
	static inline auto&CClassNameA() {
		if constexpr (member_CClassNameA_of<AnyChild>::template compatible_to<StringA(AnyChild:: *)()>)
			ret_as(AnyChild::CClassNameA())
		else {
			misdef_assert(!member_CClassNameA_of<AnyChild>::is_existed,
						  "Member CClassNameA must be compatible to StringA()");
			static const StringA _ClassNameA = CString(typeid(Child).name(), MaxLenClass);
			return _ClassNameA;
		}
	}
	static inline auto&CClassNameW() {
		if constexpr (member_CClassNameW_of<AnyChild>::template compatible_to<StringW(AnyChild:: *)()>)
			ret_as(AnyChild::CClassNameW())
		else {
			misdef_assert(!member_CClassNameW_of<AnyChild>::is_existed,
						  "Member CClassNameA must be compatible to StringW()");
			static const StringW _ClassNameW = FitsW(CClassNameA());
			return _ClassNameW;
		}
	}
	template<bool IsUnicode = Native::IsUnicode>
	static inline auto&CClassName() {
		if constexpr (IsUnicode)
			 ret_as(CClassNameW())
		else ret_as(CClassNameA())
	}
protected:
	template<bool IsUnicode>
	class XClassX : public WindowClassX<IsUnicode> {
		using LPCTSTR = LPCXSTR<IsUnicode>;
	public:
		using Super = WindowClassX<IsUnicode>;
	public:
		XClassX() {
			Super::WndProc(MainProc);
			Super::Name(CClassName<IsUnicode>());
			Super::Cursor(IDC_ARROW);
			Super::Styles(ClassStyle::Redraw);
			Super::Background(SysColor::Window);
		}
	};
	using XClass = XClassX<IsUnicode>;
	using XClassA = XClassX<false>;
	using XClassW = XClassX<true>;
protected:
	template<bool IsUnicode>
	class XClassExX : public WindowClassExX<IsUnicode> {
		using LPCTSTR = LPCXSTR<IsUnicode>;
	public:
		using Super = WindowClassExX<IsUnicode>;
	public:
		XClassExX() {
			Super::WndProc(MainProc);
			Super::Name(CClassName<IsUnicode>());
			Super::Cursor(IDC_ARROW);
			Super::Styles(ClassStyle::Redraw);
			Super::Background(SysColor::Window);
		}
	};
	using XClassEx = XClassExX<IsUnicode>;
	using XClassExA = XClassExX<false>;
	using XClassExW = XClassExX<true>;
private:
	static inline const auto &DefCClass() {
		static XClassEx _Class;
		ret_as(_Class)
	}
private:
	ref_member(Register);
	static inline ATOM DefRegister() {
		if (_ClassAtom) return _ClassAtom;
		return _ClassAtom = DefCClass().Register();
	}
public:
	static inline auto Register() {
		if constexpr (member_Register_of<AnyChild>::is_addressable)
			 ret_as(AnyChild::Register())
		else ret_as(DefRegister())
	}
private:
	static inline void DefUnregister() {
		if (_ClassAtom)
			DefCClass().Unregister();
		_ClassAtom = 0;
	}
public:
	static inline void Unregister() {
		if constexpr (!IsSameType(AnyChild::Unregister, Unregister))
			 ret_as(AnyChild::Unregister())
		elif constexpr (AnyChild::Unregister != Unregister)
			 ret_as(AnyChild::Unregister())
		else ret_as(DefUnregister())
	}
#pragma endregion

#pragma region Creature Management
protected:
	template<bool IsUnicode, class Style = WStyle, class StyleEx = WStyleEx>
	class CreateStructX : public WandX::CreateStructX<IsUnicode, Style, StyleEx> {
		friend class WindowBase;
		using_structx(CREATESTRUCT);
		using LPCTSTR = LPCXSTR<IsUnicode>;
	public:
		using Super = WandX::CreateStructX<IsUnicode, Style, StyleEx>;
	public:
		CreateStructX(CreateStructX &cs) : Super(cs) {
			cs.Param(O);
		}
		CreateStructX(Child &c, HWND hParent) {
			Super::Parent(hParent);
			Super::Class(Register());
			Super::Param(std::addressof(c));
			Super::Size(CW_USEDEFAULT);
			Super::Position(CW_USEDEFAULT);
			Super::Styles(WS::OverlappedWindow);
		}
		CreateStructX(const CREATESTRUCT &lpCreate, Child &c) : Super(lpCreate) {
			Super::Class(Register());
			Super::Param(std::addressof(c));
		}
		~CreateStructX() ret_to(AutoCreate());
	public:
		inline void AutoCreate() const {
			if (auto pChild = Super::template Param<Child>(); !*pChild)
				pChild->hWnd = Super::Create();
		}
		inline void AutoCreateMDI() const {
			if (auto pChild = Super::template Param<Child>(); !*pChild)
				pChild->hWnd = Super::CreateMDI();
		}
	private: // Remove properties
		/* W */ using Super::Param;
	public: // Deleted properties
		/* W */ inline auto&Class(LPCTSTR) = delete;
		/* W */ inline auto&Class(ATOM) = delete;
	};
	template<class Style = WStyle, class StyleEx = WStyleEx>
	using CreateStruct = CreateStructX<IsUnicode, Style, StyleEx>;
	template<class Style = WStyle, class StyleEx = WStyleEx>
	using CreateStructA = CreateStructX<false, Style, StyleEx>;
	template<class Style = WStyle, class StyleEx = WStyleEx>
	using CreateStructW = CreateStructX<true, Style, StyleEx>;
public:
	inline auto Create(HWND hParent = O) ret_as(CreateStruct(child, hParent));
	inline auto CreateA(HWND hParent = O) ret_as(CreateStructA(child, hParent));
	inline auto CreateW(HWND hParent = O) ret_as(CreateStructW(child, hParent));
	inline void Create(const CREATESTRUCTA &cs) ret_to(Create(CreateStructA(cs, child).Class(Register())));
	inline void Create(const CREATESTRUCTW &cs) ret_to(Create(CreateStructW(cs, child).Class(Register())));
	inline void Create(CreateStructA<> cs) ret_to(hWnd = cs.Param(pchild).Class(Register()).Create());
	inline void Create(CreateStructW<> cs) ret_to(hWnd = cs.Param(pchild).Class(Register()).Create());
	inline void Destroy() ret_to(WandX::DestroyWindow(self));
	inline void Close() ret_to(WandX::CloseWindow(self));
#pragma endregion

#pragma region Properties
public: // Property - Iconic
	/* W */ inline auto&Iconic(bool bIconic) ret_to_child(if (bIconic) WandX::OpenIcon(self));
	/* R */ inline bool Iconic() const ret_as(WandX::IsIconic(self));
public: // Property - Zoomed
	/* R */ inline bool Zoomed() const ret_as(WandX::IsZoomed(self));
public: // Property - Visible
	/* W */ inline auto&Visible(bool bVisible) ret_to_child(WandX::ShowWindow(self, bVisible ? SW_SHOW : SW_HIDE));
	/* R */ inline bool Visible() const ret_as(WandX::IsWindowVisible(self));
public: // Proterty - Enabled
	/* W */ inline auto&Enabled(bool bEnable) ret_to_child(WandX::EnableWindow(self, bEnable));
	/* R */ inline bool Enabled() const ret_as(WandX::IsWindowEnabled(self));
public: // Property - Unicode
	/* R */ inline bool Unicode() const ret_as(WandX::IsWindowUnicode(self));
public: // Property - ClientRect
	/* R */ inline WandX::Rect ClientRect() const ret_to(WandX::Rect r; WandX::GetClientRect(self, &r), r);
public: // Property - ClientSize
	/* R */ inline WandX::Size ClientSize() const ret_to(WandX::Rect r; WandX::GetClientRect(self, &r), r.size());
public: // Property - Position
	/* W */ inline auto&Position(Point ptPosition) ret_to_child(WandX::SetWindowPos(self, O, ptPosition.x, ptPosition.y, 0, 0, SWP_NOSIZE | SWP_NOACTIVATE));
	/* R */ inline Point Position() const ret_to(WandX::Rect r; WandX::GetWindowRect(self, &r), r.left_top());
public: // Property - Size
